{
  "providers": {
    "openrouter": {
      "api_base": "https://openrouter.ai/api/v1",
      "api_type": "openai",
      "api_key_env": "OPENROUTER_API_KEY"
    },
    "openrouter_vision": {
      "api_base": "https://openrouter.ai/api/v1",
      "api_type": "openai",
      "api_key_env": "OPENROUTER_API_KEY"
    },
    "kilo": {
      "api_base": "https://api.kilo.ai/v1",
      "api_type": "openai",
      "api_key_env": "KILO_API_KEY"
    }
  },
  "offers": {
    "text": {
      "openrouter_trinity": {"provider": "openrouter", "model": "arcee-ai/trinity-large-preview:free"},
      "openrouter_nemotron_text": {"provider": "openrouter", "model": "nvidia/nemotron-3-nano-30b-a3b:free"},
      "kilo_glm5": {"provider": "kilo", "model": "z-ai/glm-5:free"}
    },
    "vision": {
      "openrouter_vision_primary": {"provider": "openrouter_vision", "model": "nvidia/nemotron-nano-12b-v2-vl:free"},
      "openrouter_nemotron_vl": {"provider": "openrouter_vision", "model": "nvidia/nemotron-nano-12b-v2-vl:free"}
    }
  },
  "routes": {
    "text": {
      "primary": "openrouter_trinity",
      "fallbacks": ["kilo_glm5"]
    },
    "vision": {
      "primary": "openrouter_vision_primary",
      "fallbacks": ["openrouter_nemotron_vl"]
    },
    "browser": {
      "text": {
        "primary": "openrouter_trinity",
        "fallbacks": ["kilo_glm5"]
      },
      "vision": {
        "primary": "openrouter_vision_primary",
        "fallbacks": ["openrouter_nemotron_vl"]
      }
    }
  },
  "error_policy": {
    "retry_statuses": [429, 503, 504],
    "max_retries_per_offer": 2,
    "backoff_seconds": 1.5,
    "backoff_multiplier": 2.0
  },
  "logging": {
    "level": "INFO"
  },
  "runtime": {
    "workspace_dir": "/absolute/path/to/workspace"
  },
  "integrations": {
    "telegram_bot_token_env": "TELEGRAM_BOT_TOKEN",
    "telegram_chat_id_env": "TELEGRAM_CHAT_ID"
  }
}
