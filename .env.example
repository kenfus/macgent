# OpenRouter - free models (get key at https://openrouter.ai)
REASONING_API_TYPE=openai
REASONING_API_BASE=https://openrouter.ai/api/v1
REASONING_API_KEY=your-openrouter-key-here
# Good free options: arcee-ai/trinity-large-preview:free, google/gemma-3-27b-it:free,
# meta-llama/llama-3.3-70b-instruct:free, qwen/qwen3-coder:free
REASONING_MODEL=arcee-ai/trinity-large-preview:free

# Vision (optional - for screenshot understanding on SPAs)
VISION_API_TYPE=openai
VISION_API_BASE=https://openrouter.ai/api/v1
VISION_API_KEY=your-openrouter-key-here
VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# --- Alternative providers ---

# Anthropic (paid)
# REASONING_API_TYPE=anthropic
# REASONING_API_BASE=https://api.anthropic.com
# REASONING_API_KEY=sk-ant-...
# REASONING_MODEL=claude-haiku-4-5-20251001

# Agent settings
MAX_STEPS=40
STEP_DELAY=1.0
USE_VISION=false

# Telegram Bot (optional - for CEO communication via @MacGentBot)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
