# Reasoning model (text-only, decides actions)
REASONING_API_TYPE=anthropic          # anthropic | openai | nvidia
REASONING_API_BASE=https://api.anthropic.com
REASONING_API_KEY=sk-ant-...
REASONING_MODEL=claude-haiku-4-5-20251001

# Vision model (describes screenshots)
VISION_API_TYPE=openai                # openai | anthropic | nvidia
VISION_API_BASE=https://api.openai.com/v1
VISION_API_KEY=sk-...
VISION_MODEL=gpt-4o-mini

# --- Alternative free providers ---

# NVIDIA (free, OpenAI-compatible)
# REASONING_API_TYPE=openai
# REASONING_API_BASE=https://integrate.api.nvidia.com/v1
# REASONING_API_KEY=nvapi-...
# REASONING_MODEL=z-ai/glm5

# Kilo (free local proxy - run `kilo serve --port 8888` first)
# REASONING_API_TYPE=openai
# REASONING_API_BASE=http://127.0.0.1:8888/v1
# REASONING_API_KEY=not-needed
# REASONING_MODEL=claude-3-5-sonnet

# Agent settings
MAX_STEPS=30
USE_VISION=true
