# Core API keys (provider auth only)
REASONING_API_KEY=your-openrouter-key-here
VISION_API_KEY=your-openrouter-key-here
KILO_API_KEY=your-kilo-key-here

# Structured model routing config
MACGENT_CONFIG_PATH=./macgent_config.json
MACGENT_NAME=MacGent
# Suggested: set to <repo>/workspace (wizard asks this on first run)
# MACGENT_WORKSPACE_DIR=/absolute/path/to/your/workspace

# Runtime
MAX_STEPS=40
STEP_DELAY=1.0
USE_VISION=false
BROWSER_MODE=agent_browser
BROWSER_HEADED=false
CAPTCHA_AUTO_ATTEMPTS=1
MEMORY_RECENT_DAYS=2
MEMORY_TOP_K=5

# Optional overrides
REASONING_API_BASE=https://openrouter.ai/api/v1
VISION_API_BASE=https://openrouter.ai/api/v1
KILO_API_BASE=https://api.kilo.ai/v1
BRAVE_SEARCH_API_BASE=https://api.search.brave.com
BRAVE_SEARCH_API_KEY=your-brave-search-key-here

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
